@model List<TravelAgency.Models.Package>

@{
    ViewData["Title"] = "Home";
}

<div class="hero">
    <h1>Discover Your Next Adventure</h1>
    <p class="lead">Explore the world's most beautiful destinations</p>
    <form method="get" action="/packages" class="mt-4">
        <div class="input-group" style="max-width: 500px; margin: 0 auto;">
            <input type="text" class="form-control" name="search" placeholder="Search destination..." />
            <button class="btn btn-light" type="submit">Search</button>
        </div>
    </form>
</div>

<div class="container">
    <h2 class="mb-4" style="color: #667eea;">Featured Packages - @ViewBag.TotalPackages Total</h2>
    
    <div class="row">
        @foreach (var package in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="@package.ImageUrl" class="card-img-top" alt="@package.Destination" onerror="this.src='/images/placeholder.jpg'" />
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="card-title mb-0">@package.Destination</h5>
                            <small class="text-muted">@package.Country</small>
                        </div>
                        
                        <span class="badge bg-secondary mb-2">@package.PackageType</span>
                        
                        <p class="text-muted small">📅 @package.StartDate.ToString("MMM dd") - @package.EndDate.ToString("MMM dd")</p>

                        <p class="card-text">@package.Description</p>

                        <h4 class="text-primary mb-3">${{ package.Price }}</h4>

                        <a href="/packages/details/@package.Id" class="btn btn-primary w-100">View Details & Book</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center my-5">
        <a href="/packages" class="btn btn-lg btn-outline-primary">Browse All @ViewBag.TotalPackages Packages</a>
    </div>

    <!-- Reviews Section -->
    @if (ViewBag.Ratings != null && ((List<TravelAgency.Models.WebsiteRating>)ViewBag.Ratings).Count > 0)
    {
        <div class="mt-5 bg-light-primary p-4 rounded">
            <h3 class="text-center mb-4">What Users Think About Us</h3>
            <div class="row">
                @foreach (var rating in ViewBag.Ratings)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <div class="mb-2">
                                    @for (int i = 0; i < rating.Rating; i++)
                                    {
                                        <span style="color: #ffc107;">★</span>
                                    }
                                </div>
                                <p class="card-text">@rating.Comment</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>