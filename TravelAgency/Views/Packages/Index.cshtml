@model List<TravelAgency.Models.Package>

@{
    ViewData["Title"] = "All Packages";
}

<div class="hero">
    <h1>All Travel Packages</h1>
    <p class="lead">Browse our collection of @ViewBag.TotalPackages amazing destinations</p>
</div>

<div class="container mb-5">
    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-md-3 mb-4">
            <form method="get" class="card p-3">
                <h5 class="mb-4">Filter & Search</h5>
                
                <div class="mb-3">
                    <label class="form-label">Search</label>
                    <input type="text" class="form-control" name="search" placeholder="Destination..." />
                </div>

                <div class="mb-3">
                    <label class="form-label">Destination</label>
                    <input type="text" class="form-control" name="destination" placeholder="City..." />
                </div>

                <div class="mb-3">
                    <label class="form-label">Country</label>
                    <input type="text" class="form-control" name="country" placeholder="Country..." />
                </div>

                <div class="mb-3">
                    <label class="form-label">Price Range</label>
                    <div class="input-group mb-2">
                        <input type="number" class="form-control" name="minPrice" placeholder="Min" />
                    </div>
                    <div class="input-group">
                        <input type="number" class="form-control" name="maxPrice" placeholder="Max" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Sort By</label>
                    <select class="form-select" name="sortBy">
                        <option value="">Newest</option>
                        <option value="price-asc">Price: Low to High</option>
                        <option value="price-desc">Price: High to Low</option>
                        <option value="date">Travel Date</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
                <a href="/packages" class="btn btn-secondary w-100 mt-2">Clear All</a>
            </form>
        </div>

        <!-- Packages Grid -->
        <div class="col-md-9">
            @if (Model.Count > 0)
            {
                <div class="row">
                    @foreach (var package in Model)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <img src="@package.ImageUrl" class="card-img-top" alt="@package.Destination" onerror="this.src='/images/placeholder.jpg'" />
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h5 class="card-title">@package.Destination</h5>
                                            <small class="text-muted">@package.Country</small>
                                        </div>
                                        <span class="badge bg-info">@package.PackageType</span>
                                    </div>

                                    <p class="text-muted small">📅 @package.StartDate.ToString("MMM dd") - @package.EndDate.ToString("MMM dd, yyyy")</p>

                                    <p class="card-text flex-grow-1">@package.Description</p>

                                    <h4 class="text-primary mb-3">${{ package.Price }}</h4>

                                    <a href="/packages/details/@package.Id" class="btn btn-primary w-100">View Details & Book</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <h5>No packages found</h5>
                    <p>Try adjusting your filters or search terms.</p>
                </div>
            }

            <p class="text-muted text-center mt-3">Showing @Model.Count of @ViewBag.TotalPackages packages</p>
        </div>
    </div>
</div>